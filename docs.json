{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Reeva",
  "description": "Reeva product documentation — build AI agents that link engineering documents and data between Teamcenter, SAP, and your other manufacturing systems.",
  "colors": {
    "primary": "#00B777",
    "light": "#26D194",
    "dark": "#003527"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "/support"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "get-started/overview",
          "get-started/quickstart"
        ]
      },
      {
        "group": "Agents",
        "icon": "workflow",
        "expanded": true,
        "pages": [
          "agents/build",
          "agents/monitor"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/teamcenter",
          "integrations/sap"
        ]
      },
      {
        "group": "Use cases",
        "icon": "factory",
        "expanded": true,
        "pages": [
          "use-cases/engineering-doc-sync",
          "use-cases/change-orders"
        ]
      },
      {
        "group": "Administration",
        "icon": "shield",
        "expanded": true,
        "pages": [
          "administration/users-and-audit"
        ]
      },
      {
        "group": "Help",
        "icon": "life-buoy",
        "expanded": true,
        "pages": [
          "troubleshooting",
          "support"
        ]
      },
      {
        "group": "Changelog",
        "icon": "history",
        "expanded": true,
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@reeva.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://app.reeva.ai"
    }
  },
  "footer": {
    "socials": {}
  }
}
